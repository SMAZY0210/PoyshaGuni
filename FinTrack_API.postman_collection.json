{
  "info": {
    "name": "FinTrack API",
    "description": "Complete API collection for FinTrack Finance App",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/signup",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.token) pm.collectionVariables.set('token', res.token);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Expenses",
      "item": [
        {
          "name": "Get All Expenses",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/expenses?month=5&year=2026",
              "query": [
                { "key": "month", "value": "5" },
                { "key": "year", "value": "2026" },
                { "key": "category", "value": "Food", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Add Expense",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/expenses",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Lunch at restaurant\",\n  \"amount\": 25.50,\n  \"category\": \"Food\",\n  \"date\": \"2026-05-02\",\n  \"note\": \"Team lunch\"\n}"
            }
          }
        },
        {
          "name": "Update Expense",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/expenses/EXPENSE_ID_HERE",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Lunch\",\n  \"amount\": 30.00,\n  \"category\": \"Food\",\n  \"date\": \"2026-05-02\"\n}"
            }
          }
        },
        {
          "name": "Delete Expense",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/expenses/EXPENSE_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Income",
      "item": [
        {
          "name": "Get All Income",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/income",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Add Income",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/income",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"Monthly Salary\",\n  \"amount\": 5000,\n  \"date\": \"2026-05-01\",\n  \"note\": \"May salary\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/dashboard?month=5&year=2026",
              "query": [
                { "key": "month", "value": "5" },
                { "key": "year", "value": "2026" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
